# Hackathon Requirement 7: Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# OPTION 1: Use HuggingFace Models (Recommended for HF Spaces)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# OPTION 2: Use OpenAI API
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-3.5-turbo
# HF_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Note for HF Spaces Deployment:
# 1. Get your HuggingFace token from: https://huggingface.co/settings/tokens
# 2. In HF Spaces settings, add these as Repository Secrets:
#    - API_BASE_URL
#    - MODEL_NAME
#    - HF_TOKEN
# 3. The app will load them as environment variables automatically